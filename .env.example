# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="defina-um-segredo-longo-aqui"
APP_HOST="0.0.0.0"

# App
NEXT_PUBLIC_APP_NAME="BarberMain"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Em producao, use o dominio publico que recebera o webhook da Evolution.
PUBLIC_APP_URL="http://localhost:3000"
APP_TIMEZONE="America/Sao_Paulo"

# Evolution API
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE=""
EVOLUTION_WEBHOOK_SECRET=""
# Opcional: força o tenant da Evolution para um slug especifico de barbearia.
EVOLUTION_BARBERSHOP_SLUG=""
WHATSAPP_APPOINTMENT_BUFFER_MINUTES="5"
WHATSAPP_MIN_LEAD_TIME_MINUTES="20"

# OpenAI Server Features
# Variaveis usadas apenas no servidor. Nao use prefixo NEXT_PUBLIC.
# Sem OPENAI_API_KEY, o sistema usa apenas fallbacks deterministicos locais.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_TIMEOUT_MS="15000"

# Campaign Automation
# Seguro por padrao: a automacao sobe desligada ate validacao manual.
# Quando vazio, o scheduler interno usa NEXTAUTH_SECRET.
AUTOMATION_RUNNER_SECRET=""
CUSTOMER_CAMPAIGN_AUTOMATION_ENABLED="false"

# PostgreSQL Backup
POSTGRES_BACKUP_DIR="/var/backups/barbermain/postgres"
POSTGRES_BACKUP_RETENTION_DAILY="7"
POSTGRES_BACKUP_CRON_HOUR="3"
POSTGRES_BACKUP_CRON_MINUTE="15"
POSTGRES_BACKUP_TIMEZONE="America/Sao_Paulo"
# Opcional: sobrescreve o container do Postgres usado pelo docker exec no host.
POSTGRES_BACKUP_CONTAINER=""
