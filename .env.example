# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="defina-um-segredo-longo-aqui"

# App
NEXT_PUBLIC_APP_NAME="BarberOS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PUBLIC_APP_URL="http://localhost:3000"

# Evolution API
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE=""
EVOLUTION_WEBHOOK_SECRET=""

# OpenAI Business Analyst
# Variaveis usadas apenas no servidor. Nao use prefixo NEXT_PUBLIC.
# Sem OPENAI_API_KEY, o sistema usa apenas o motor deterministico local.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"
OPENAI_TIMEOUT_MS="15000"
